# ─── Supabase ────────────────────────────────────────────────
# Obtener en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Usuarios (3 cuentas del equipo) ─────────────────────────
USER1_EMAIL=usuario1@reasy.cl
USER1_PASSWORD=contraseña_segura_1
USER1_NAME=Carlos

USER2_EMAIL=usuario2@reasy.cl
USER2_PASSWORD=contraseña_segura_2
USER2_NAME=Nombre 2

USER3_EMAIL=usuario3@reasy.cl
USER3_PASSWORD=contraseña_segura_3
USER3_NAME=Nombre 3

# ─── Sync manual desde dashboard ─────────────────────────────
# Obtener en: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_...
# URL: https://api.github.com/repos/TU_USUARIO/reasy-web/dispatches
GITHUB_DISPATCH_URL=https://api.github.com/repos/TU_USUARIO/reasy-web/dispatches

# ─── Seguridad del cron ───────────────────────────────────────
CRON_SECRET=genera_una_cadena_aleatoria_larga
